# ─── Required ────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT signing secret — use a long random string
JWT_SECRET=replace_with_a_long_random_secret

# ─── Email (Nodemailer / Gmail) ───────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# ─── AI Assistant (optional) ─────────────────────────────────
XAI_API_KEY=your-xai-grok-api-key

# ─── M-Pesa (optional) ───────────────────────────────────────
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-railway-domain.up.railway.app/api/payments/mpesa-callback

# ─── WhatsApp Bot (optional) ─────────────────────────────────
WHATSAPP_BOT_ENABLED=false
WHATSAPP_PHONE_NUMBER=254xxxxxxxxx

# ─── App Config ──────────────────────────────────────────────
NODE_ENV=production
PORT=8080
ALLOWED_ORIGINS=https://your-railway-domain.up.railway.app

# ─── Admin Setup (optional) ──────────────────────────────────
ADMIN_SETUP_KEY=replace_with_a_secret_key
